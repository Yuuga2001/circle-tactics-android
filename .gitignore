# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — use .env.example as template
.env
.env*.local

# IDE
.idea/
*.orig.*

# test coverage output
coverage/

# native secrets and signing
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# typescript
*.tsbuildinfo

# Android: machine-specific and build outputs
android/local.properties
android/.gradle/
android/build/
android/app/build/
android/.cxx/
android/app/.cxx/
android/.kotlin/
android/app/.kotlin/

# iOS (not used in this project)
/ios
